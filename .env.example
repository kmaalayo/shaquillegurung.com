# Copy to .env for local development (never commit your real .env).

# Local dev port. Railway sets PORT automatically in production, so leave this
# out there. Locally we avoid 3000 (ReTeach) and 3100 (ClaimSarathi).
PORT=5050

# --- The Guide (chat widget) + lead email ---

# Claude API key — powers POST /api/chat. Get one at https://console.anthropic.com.
# ANTHROPIC_API_KEY=

# Resend — delivers project leads (the Guide's submit_project_lead tool + /api/contact).
# Get a key at https://resend.com. CONTACT_TO is where leads land (your Gmail is reliable
# immediately; a domain address needs forwarding set up first).
# RESEND_API_KEY=
# CONTACT_TO=you@example.com

# Optional: the "from" address for lead emails. Defaults to Resend's test sender
# (onboarding@resend.dev), which works with no domain verification and delivers to the
# Resend account owner's email. Set this to e.g. "The Guide <guide@shaquillegurung.com>"
# only after you've verified the domain in Resend.
# LEAD_FROM=
